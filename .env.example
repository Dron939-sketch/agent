# ================================================================
# Фреди — .env.example
# Скопируй в .env и заполни нужные ключи.
# Всё помечено [required] / [recommended] / [optional]. Пустое =
# соответствующая фича отключится, код gracefully деградирует.
# ================================================================

# ---------------- Core / Security ----------------
# [required] секрет для JWT и cookie
# генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
# [required] где хранить данные (dev: sqlite, prod: postgres)
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db
# [optional] публичный URL для self-ping / push colback
SELF_PUBLIC_URL=http://localhost:8000
# [optional] дополнительные CORS origin'ы, через запятую
CORS_ALLOW_ORIGINS=

# ---------------- App ----------------
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ---------------- LLM провайдеры ----------------
# Хотя бы один из LLM ключей должен быть задан — иначе chat вернёт пусто.
# Роутер пробует в порядке: Claude → GPT → DeepSeek → Ollama.
# [recommended] основной провайдер для smart-профиля
ANTHROPIC_API_KEY=
# [recommended] fallback + fast-профиль
OPENAI_API_KEY=
# [optional] дешёвый fallback
DEEPSEEK_API_KEY=
# [optional] локальная LLM через ollama
OLLAMA_BASE_URL=http://localhost:11434

# ---------------- Voice: STT (Deepgram) ----------------
# [recommended] без него endpoint /api/voice/stt вернёт 503
DEEPGRAM_API_KEY=

# ---------------- Voice: TTS ----------------
# [recommended] Yandex SpeechKit (основной голос — madirus, «Бикович»-стиль)
YANDEX_API_KEY=
# [optional] ElevenLabs — альтернативный высококачественный TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# ---------------- Voice emotion (Hume AI) ----------------
# [optional] определение эмоций по голосу; без него — только текстовая эмоция
HUME_API_KEY=

# ---------------- Image generation (Replicate FLUX) ----------------
# [optional] /api/vision генерация картинок
REPLICATE_API_TOKEN=

# ---------------- Push notifications (VAPID) ----------------
# [optional] для Web Push. Генерация пары:
# python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('priv:', v.private_pem().decode()); print('pub:', v.public_key_urlsafe_b64)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@freddy.local

# ---------------- VAD ----------------
# webrtc (default) | silero
VAD_MODE=webrtc

# ---------------- Tools / External APIs ----------------
# [recommended] погода (используется в tool + situational awareness)
OPENWEATHER_API_KEY=
# [optional] web search
TAVILY_API_KEY=
# [optional] github tools (repo info и т.д.)
GITHUB_TOKEN=
GITHUB_REPO=

# ---------------- Storage (vector / cache) ----------------
# [optional] для Qdrant-backed memory (иначе — SQL store)
QDRANT_URL=
# [optional] для rate limit / кэша
REDIS_URL=

# ---------------- Integrations (все опциональны) ----------------

# --- Telegram bot plugin ---
# [optional] при пустом плагин не стартует
TELEGRAM_BOT_TOKEN=

# --- Spotify plugin (music control) ---
# Получить: https://developer.spotify.com/dashboard → создать приложение → OAuth flow
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Notion plugin ---
# https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DEFAULT_PAGE_ID=

# --- Google Calendar plugin ---
# JSON service-account (полный JSON ОДНОЙ СТРОКОЙ, в кавычках)
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=

# --- Email plugin (IMAP + SMTP) ---
# Для Gmail: включи 2FA и создай App Password
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# --- Home Assistant plugin ---
# URL вида http://homeassistant.local:8123 + long-lived token
HASS_URL=
HASS_TOKEN=

# ---------------- Observability ----------------
# [optional] Sentry для error tracking
SENTRY_DSN=
