{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Varitype Knowledge Base Schema",
  "description": "Схема для валидации БЗ Вариатики",
  "type": "object",
  "required": ["version", "vectors", "part_2_geographic", "part_3_integration"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "vectors": {
      "type": "object",
      "properties": {
        "СБ": { "$ref": "#/definitions/vector" },
        "ТФ": { "$ref": "#/definitions/vector" },
        "УБ": { "$ref": "#/definitions/vector" },
        "ЧВ": { "$ref": "#/definitions/vector" }
      }
    }
  },
  "definitions": {
    "vector": {
      "type": "object",
      "required": ["name", "essence", "core_fear", "core_need", "blind_spot", "language", "levels"],
      "properties": {
        "levels": {
          "type": "object",
          "minProperties": 6,
          "maxProperties": 6,
          "patternProperties": {
            "^[1-6]$": { "$ref": "#/definitions/level" }
          }
        }
      }
    },
    "level": {
      "type": "object",
      "required": ["test", "varitype", "name", "stress", "resources", "understanding", "relationships", "what_they_ask", "what_they_need", "how_to_lead", "route_to_better_life"]
    }
  }
}
